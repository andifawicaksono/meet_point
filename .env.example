# ─────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meetpoint
DB_USER=meetpoint_user
DB_PASSWORD=your_strong_db_password_here
DATABASE_URL=postgresql://meetpoint_user:your_strong_db_password_here@localhost:5432/meetpoint

# ─────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password_here

# ─────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CSRF_SECRET=replace_with_a_csrf_secret_min_32_chars

# ─────────────────────────────────────────────────────────
# CLIENT (Vite — prefix with VITE_ to expose to browser)
# ─────────────────────────────────────────────────────────
VITE_SERVER_URL=http://localhost:3001
